# Copy this file to .env and fill in your values
# .env is in .gitignore — never commit it

# OpenAI API key
OPENAI_API_KEY=sk-...

# Qdrant connection (default: localhost)
QDRANT_URL=http://localhost:6333

# Qdrant collection name
COLLECTION_NAME=p3_multidoc

# RAG UI password (first factor)
RAG_PASSWORD=your_password_here

# TOTP secret for Google Authenticator (second factor)
# Generate with: python3 -c "import pyotp; print(pyotp.random_base32())"
RAG_TOTP_SECRET=your_base32_secret_here
